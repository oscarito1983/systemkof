<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.video.torrentbridge" name="Torrent Bridge" version="1.0.0" provider-name="Anistream">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.1"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="es">Puente multi-proveedor para Elementum</summary>
        <description lang="es">Busca torrents en Torrentio, TPB y EZTV (1080p/720p) con prioridad de idiomas y los reproduce en Elementum.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>

<addon id="repository.oscar" name="Oscar Repository" version="1.0.0" provider-name="Oscar">
    <extension point="xbmc.addon.repository" name="Oscar Repository">
        <dir>
            <info compressed="false">https://oscarito1983.github.io/systemkof/addons.xml</info>
            <checksum>https://oscarito1983.github.io/systemkof/addons.xml.md5</checksum>
            <datadir zip="true">https://oscarito1983.github.io/systemkof/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Repositorio de Oscar para Kodi</summary>
        <description>Contiene el buscador de torrents profesional Torrent Bridge.</description>
        <platform>all</platform>
    </extension>
</addon>

</addons>