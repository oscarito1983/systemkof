<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.torrentbridge" name="Torrent Bridge" version="1.0.0" provider-name="Anistream">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.1"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="es">Puente multi-proveedor para Elementum</summary>
        <description lang="es">Busca torrents en Torrentio, TPB y EZTV (1080p/720p) con prioridad de idiomas y los reproduce en Elementum.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
